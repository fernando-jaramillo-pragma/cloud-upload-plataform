{
  "name": "image-processor",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/image-processor/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/packages/image-processor",
        "format": ["cjs"],
        "bundle": true,
        "external": ["sharp"],
        "main": "packages/image-processor/src/main.ts",
        "tsConfig": "packages/image-processor/tsconfig.app.json",
        "assets": ["packages/image-processor/src/assets"],
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/packages/image-processor/package.json",
        "{workspaceRoot}/dist/packages/image-processor/pnpm-lock.yaml"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/packages/image-processor/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "package": {
      "dependsOn": ["build"],
      "cache": false,
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/image-processor.zip"],
      "options": {
        "parallel": false,
        "commands": [
          "echo '{\"dependencies\":{\"sharp\":\"^0.34.2\"}}' > dist/packages/image-processor/package.json",
          "npm install --prefix dist/packages/image-processor --cpu=x64 --os=linux sharp --no-package-lock",
          "cd dist/packages/image-processor && zip -r ../image-processor.zip ."
        ]
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "image-processor:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "image-processor:build:development"
        },
        "production": {
          "buildTarget": "image-processor:build:production"
        }
      }
    }
  },
  "tags": []
}
