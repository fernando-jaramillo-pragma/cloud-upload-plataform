# Región de AWS donde está desplegada la Lambda
AWS_REGION=us-east-1

# Nombre exacto de la función Lambda en AWS Console
LAMBDA_FUNCTION_NAME=image-processor

# Credenciales de un IAM User con permisos para invocar la Lambda
# Política mínima requerida: lambda:InvokeFunction sobre el ARN de la función
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Cloudflare R2 — necesario para el endpoint GET /uploads (listar thumbnails)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# Tamaño máximo de las imágenes a subir (en MB)
UPLOAD_MAX_SIZE_MB=5

COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_REGION=us-east-1